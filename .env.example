# =====================================================================
# homework-pub-booking environment configuration
# =====================================================================
#
# HOW TO USE THIS FILE:
#   1. Copy this file to `.env` in the same directory:
#          cp .env.example .env
#   2. Fill in the values below.
#   3. Run `make verify` to confirm everything loads.
#
# TROUBLESHOOTING:
#   - If variables aren't being read, see docs/dotenv-101.md
#   - Quoting: both `KEY=value` and `KEY="value"` work
#   - NO trailing spaces after `=`
#   - NO `export` keyword (this isn't a shell script)
#   - The file MUST be named `.env`, not `env` or `env.txt`
#   - Smart-quote characters pasted from Notion/Word WILL break parsing
#   - Windows line endings (CRLF) also cause intermittent breakage on
#     some libraries. If you pasted from Notepad on Windows, open the
#     file in VS Code and set the line ending to LF.

# ---------------------------------------------------------------------
# REQUIRED for all exercises — LLM access via Nebius Token Factory
# ---------------------------------------------------------------------

# Your Nebius API key. Free tier is enough for all homework.
# Get one at: https://tokenfactory.nebius.com  (see docs/nebius-signup.md)
# If missing, `make verify` fails with "NEBIUS_KEY not set".
NEBIUS_KEY=

# These control which models sovereign-agent uses. Defaults below are
# the same ones used in class. Override only if you know what you're
# doing; the grader runs against the defaults.
SOVEREIGN_AGENT_LLM_BASE_URL=https://api.tokenfactory.nebius.com/v1/
SOVEREIGN_AGENT_LLM_API_KEY_ENV=NEBIUS_KEY
SOVEREIGN_AGENT_LLM_PLANNER_MODEL=Qwen/Qwen3-Next-80B-A3B-Thinking
SOVEREIGN_AGENT_LLM_EXECUTOR_MODEL=Qwen/Qwen3-32B
SOVEREIGN_AGENT_LLM_MEMORY_MODEL=meta-llama/Llama-3.3-70B-Instruct

# ---------------------------------------------------------------------
# REQUIRED for Ex6 — Rasa Pro container
# ---------------------------------------------------------------------

# Rasa Pro developer-edition license (JWT string). Rasa Pro is gated;
# the container will refuse to start without a valid license.
#
# How to get one:
#   1. Create an account at https://rasa.com/rasa-pro-developer-edition/
#   2. After approval you'll receive a JWT token via email — paste it here.
#   3. The token is a single line; do NOT wrap it in quotes.
#
# Without this, Ex6 falls back to the stdlib mock server (students can
# complete the HTTP-contract tests but not the full CALM flow tests).
RASA_PRO_LICENSE=

# ---------------------------------------------------------------------
# REQUIRED for Ex8 — Voice pipeline (STT + TTS)
# ---------------------------------------------------------------------

# Speechmatics free-tier API key (speech-to-text).
# Get one at: https://portal.speechmatics.com/signup  (see docs/speechmatics-setup.md)
# If missing, Ex8 degrades to text-only mode automatically.
SPEECHMATICS_KEY=

# Rime.ai API key (text-to-speech). We use the latest Arcana model for
# natural-sounding voice output.
# Get one at: https://rime.ai — sign up for the API tier.
# Free tier is enough for the homework. If missing, Ex8 prints the
# manager's replies as text instead of synthesising them.
RIME_API_KEY=

# ---------------------------------------------------------------------
# OPTIONAL — sessions directory override
# ---------------------------------------------------------------------

# Where to store homework session artifacts. Defaults to your OS
# user-data directory (see sovereign-agent docs). Override if you
# want to pin them somewhere specific (e.g. onto a scratch SSD).
# SOVEREIGN_AGENT_DATA_DIR=

# ---------------------------------------------------------------------
# OPTIONAL — grading
# ---------------------------------------------------------------------

# Your GitHub username. The grader uses this to cross-check your
# submission. Not required for local `make check-submit` but MUST be
# set before CI-based final grading runs.
STUDENT_GITHUB_USERNAME=

# Your cohort tag. Nebius cohort students should leave this as the
# default. Self-paced students can ignore it.
COHORT_TAG=nebius-2026-04
